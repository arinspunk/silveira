{
	"name": "silveira-theme",
	"private": true,
	"type": "module",
	"description": "Vite build outputs to assets/ (committed for deploy without Node on server). Run npm run build after src/ changes. Use npm run build (not vite build alone) so lint runs via prebuild.",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"prebuild": "npm run validate",
		"validate": "npm run lint && npm run lint:css",
		"lint": "eslint src vite.config.js eslint.config.js stylelint.config.js",
		"lint:css": "stylelint \"src/**/*.{css,scss}\"",
		"format": "prettier --write \"src/**/*.{js,css,scss}\" \"vite.config.js\" \"eslint.config.js\" \"stylelint.config.js\"",
		"format:check": "prettier --check \"src/**/*.{js,css,scss}\" \"vite.config.js\" \"eslint.config.js\" \"stylelint.config.js\""
	},
	"devDependencies": {
		"@eslint/js": "^9.15.0",
		"eslint": "^9.15.0",
		"eslint-config-prettier": "^9.1.0",
		"globals": "^15.12.0",
		"prettier": "^3.4.2",
		"sass": "^1.77.0",
		"stylelint": "^16.11.0",
		"stylelint-config-standard-scss": "^14.0.0",
		"vite": "^6.0.0"
	}
}
