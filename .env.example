# Copiar a .env y ajustar en equipo si hace falta.
# URL canónica (también en docker-compose.yml vía WORDPRESS_CONFIG_EXTRA):
#   http://silveira.localhost  (puerto 80; sin :8070 en el navegador)
# No suele hacer falta /etc/hosts: *.localhost apunta a 127.0.0.1.
# El contenedor expone el puerto 80 del host; si ya tienes otro servicio en 80,
# cambia en docker-compose.yml el mapeo `ports` (p. ej. 8070:80) y la URL en WORDPRESS_CONFIG_EXTRA.

MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root
WORDPRESS_TABLE_PREFIX=wp_
