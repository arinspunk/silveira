# Copiar a .env y ajustar en equipo si hace falta.
# URL canónica (también en docker-compose.yml vía WORDPRESS_CONFIG_EXTRA):
#   http://silveira.localhost  (puerto 80; sin :8070 en el navegador)
# No suele hacer falta /etc/hosts: *.localhost apunta a 127.0.0.1.
# El contenedor expone el puerto 80 del host; si ya tienes otro servicio en 80,
# cambia en docker-compose.yml el mapeo `ports` (p. ej. 8070:80) y la URL en WORDPRESS_CONFIG_EXTRA.

MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root
WORDPRESS_TABLE_PREFIX=wp_

# --- Vite (theme silveira): NO usar WP_DEBUG para esto. Solo desarrollo local. ---
# Con 1, el theme cargará CSS/JS desde el servidor de Vite (HMR). Con 0 o sin definir, usa assets compilados.
# El navegador sigue en http://silveira.localhost; Vite suele estar en el puerto 5173 del host.
SILVEIRA_VITE_DEV=0
# Desde PHP dentro del contenedor Docker, el host es host.docker.internal (Docker Desktop Mac/Win).
# En Linux puede hacer falta otra URL; ver documentación del theme.
VITE_DEV_SERVER_URL=http://host.docker.internal:5173
